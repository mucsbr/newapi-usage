# Service listen port on the host.
PORT=8080

# Docker build network settings. Defaults are China-mainland friendly.
# To use official upstreams, replace these three values with:
#   APK_MIRROR=
#   GOPROXY=https://proxy.golang.org,direct
#   GOSUMDB=sum.golang.org
APK_MIRROR=https://mirrors.aliyun.com/alpine
GOPROXY=https://goproxy.cn,direct
GOSUMDB=sum.golang.google.cn

# Set this to the Docker network where new-api can reach its database service.
# Check with: docker network ls | grep new-api
NEWAPI_NETWORK=new-api_new-api-network

# PostgreSQL:
SQL_DSN=postgresql://root:123456@postgres:5432/new-api?sslmode=disable
DB_DRIVER=postgres

# MySQL:
# SQL_DSN=root:123456@tcp(mysql:3306)/new-api?charset=utf8mb4&parseTime=true
# DB_DRIVER=mysql

# SQLite:
# Mount the sqlite file under ./data and set SQL_DSN=/data/one-api.db
# SQL_DSN=/data/one-api.db
# DB_DRIVER=sqlite

DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
QUERY_TIMEOUT_SECONDS=30

# Defaults to false. When false, the UI only shows token id, token name, and key tail.
SHOW_FULL_KEYS=false

# Required. Used to log in to the dashboard.
ADMIN_PASSWORD=change-this-password

# Optional OpenResty request-body audit JSONL import.
# AUDIT_LOG_DIR is mounted as /audit-logs in the container.
# AUDIT_LOG_DIR=/home/asants/newapi/new-api/audit-logs
# AUDIT_LOG_GLOB=/audit-logs/*.jsonl
AUDIT_INDEX_DSN=/var/lib/newapi-usage/audit.db
# Timezone of string timestamps written by OpenResty ngx.localtime().
# Use UTC if the JSONL time is 8 hours behind China time.
AUDIT_TIMEZONE=UTC
AUDIT_SCAN_INTERVAL_SECONDS=10
AUDIT_LOOKUP_WINDOW_SECONDS=120
AUDIT_MAX_LINES_PER_SCAN=50000

# Optional channel balance cards ("渠道余额"). The whole area is hidden unless
# at least one channel below is configured.

# DeepSeek: GET {base}/user/balance with the API key. Single card, fetched live.
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_LABEL=DeepSeek

# CPA: an independent channel shown as ONE card listing every auth file's
# rate-limit usage (primary = 5h window, secondary = weekly window). CPA itself
# proxies the chatgpt request through whatever proxy it is configured with.
# Requires base url + management token. Probing runs in the background on
# CPA_REFRESH_INTERVAL_SECONDS and is served from cache.
# CPA_BASE_URL=https://cpa.example.com
# CPA_TOKEN=cpa-management-token
CPA_LABEL=CPA
CPA_TARGET_TYPE=codex
CPA_PROBE_CONCURRENCY=20
CPA_PROBE_TIMEOUT_SECONDS=15
CPA_REFRESH_INTERVAL_SECONDS=300
# Cap accounts probed per refresh (0 = no cap).
CPA_MAX_ACCOUNTS=0

# Sub2API: account list card. OAuth accounts show a live usage refresh button;
# API-key accounts only show estimated/account-list usage when available.
# SUB2API_BASE_URL=http://10.255.200.17:6780
# SUB2API_API_KEY=admin-xxxxxxxxxxxxxxxx
SUB2API_LABEL=Sub2API
SUB2API_TIMEZONE=Asia/Shanghai
SUB2API_TIMEOUT_SECONDS=15
SUB2API_PAGE_SIZE=50

TZ=Asia/Shanghai
