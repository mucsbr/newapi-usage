# Service listen port on the host.
PORT=8080

# Set this to the Docker network where new-api can reach its database service.
# Check with: docker network ls | grep new-api
NEWAPI_NETWORK=new-api_new-api-network

# PostgreSQL:
SQL_DSN=postgresql://root:123456@postgres:5432/new-api?sslmode=disable
DB_DRIVER=postgres

# MySQL:
# SQL_DSN=root:123456@tcp(mysql:3306)/new-api?charset=utf8mb4&parseTime=true
# DB_DRIVER=mysql

# SQLite:
# Mount the sqlite file under ./data and set SQL_DSN=/data/one-api.db
# SQL_DSN=/data/one-api.db
# DB_DRIVER=sqlite

DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
QUERY_TIMEOUT_SECONDS=30

# Defaults to false. When false, the UI only shows token id, token name, and key tail.
SHOW_FULL_KEYS=false

TZ=Asia/Shanghai
